# LoanLens AI — Backend Environment Variables
# Copy this to .env and fill in your values

# Database / Prisma bootstrap
# PostgreSQL is the only supported database backend.
DATABASE_PROVIDER=postgresql
DATABASE_URL=postgresql://loanlens:loanlens@localhost:5432/loanlens
DATABASE_CONNECT_TIMEOUT_SECONDS=30
PRISMA_SCHEMA_PATH=./schema.prisma
PRISMA_AUTO_GENERATE_CLIENT=true
DIRECT_URL=postgresql://loanlens:loanlens@localhost:5432/loanlens

# If you use a pooled connection for runtime queries, keep DIRECT_URL on a direct
# PostgreSQL connection so Prisma migrations can run without PgBouncer issues.
# DATABASE_URL=postgresql://postgres:password@db.example.com:6543/loanlens?pgbouncer=true
# DIRECT_URL=postgresql://postgres:password@db.example.com:5432/loanlens

# App
APP_NAME=LoanLens AI
APP_ENV=development
SECRET_KEY=your-secret-key-change-this
LOCAL_STORAGE_ENCRYPTION_KEY=
API_V1_PREFIX=/api/v1

# CORS (your Next.js frontend)
FRONTEND_URL=http://localhost:3000

# AWS S3 (for document storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=loanlens-documents
AWS_S3_ENDPOINT_URL=
AWS_KMS_ENDPOINT_URL=
AWS_KMS_KEY_ID=
AWS_S3_FORCE_PATH_STYLE=false

# LocalStack / production rehearsal example:
# AWS_ACCESS_KEY_ID=test
# AWS_SECRET_ACCESS_KEY=test
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=loanlens-rehearsal
# AWS_S3_ENDPOINT_URL=http://localstack:4566
# AWS_KMS_ENDPOINT_URL=http://localstack:4566
# AWS_KMS_KEY_ID=alias/loanlens-rehearsal
# AWS_S3_FORCE_PATH_STYLE=true

# AI Provider
GOOGLE_API_KEY=
GOOGLE_DOCUMENT_AI_PROJECT_ID=
GOOGLE_DOCUMENT_AI_LOCATION=
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=
OPENAI_API_KEY=

# OCR
OCR_PROVIDER_MODE=hybrid
OCR_RENDER_DPI=300
OCR_MIN_TEXT_LENGTH=50
OCR_MAX_CONCURRENCY=4
OCR_TESSERACT_LANGS=eng+hin

# Retention
# Set any *_DAYS value to 0 to disable that cleanup window.
RETENTION_CASE_DAYS=180
RETENTION_DOCUMENT_DAYS=180
RETENTION_AUDIT_LOG_DAYS=365
RETENTION_BATCH_SIZE=100

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER=
CLERK_JWT_AUDIENCE=
CLERK_JWT_LEEWAY_SECONDS=60
CODEX_E2E_AUTH_BYPASS=false
